# Discord Bot Credentials
# Get these from https://discord.com/developers/applications

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_application_id_here

# Optional: Guild ID for instant slash command deployment during testing
# Leave empty to register commands globally across all servers (takes ~1 hour to update globally)
GUILD_ID=

# Channel ID where YouTube/TikTok live notifications and new upload notifications will be sent
LIVE_NOTIFY_CHANNEL_ID=

